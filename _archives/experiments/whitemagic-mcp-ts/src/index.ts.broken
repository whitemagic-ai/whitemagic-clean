// Call Tool Handler
server.setRequestHandler(CallToolRequestSchema, async (request) => {
  const { name, arguments: args } = request.params;

  return safeHandler(`CallTool:${name}`, async () => {
    switch (name) {
      // Session management (unified registry tools route to client)
      case 'create_session':
      case 'create_scratchpad':
      case 'update_scratchpad':
      case 'finalize_scratchpad':
      case 'session_status':
      case 'session_checkpoint':
      case 'session_recall':
      case 'session_handoff':
      
      // Memory tools (unified registry)
      case 'create_memory':
      case 'search_memories':
      case 'read_memory':
      case 'fast_read_memory':
      case 'batch_read_memories':
      case 'parallel_search':
      case 'list_memories':
      case 'update_memory':
      case 'delete_memory':
      
      // Garden tools (unified registry)
      case 'garden_activate':
      case 'garden_status':
      case 'garden_health':
      
      // Metrics tools (unified registry)
      case 'track_metric':
      case 'get_metrics_summary':
      
      // Edge tools (unified registry)
      case 'edge_infer':
      case 'edge_batch_infer':
        return { content: [{ type: 'text', text: JSON.stringify(await callUnifiedTool(name, args || {})) }] };
      
      // Legacy tools (still using old handlers)
      case 'get_tags': {
        const tags = await client.getTags(args?.include_archived || false);
        return { content: [{ type: 'text', text: JSON.stringify(tags) }] };
      }
      
      case 'get_stats': {
        const stats = await client.getStats();
        return { content: [{ type: 'text', text: JSON.stringify(stats) }] };
      }
      
      case 'clear_memory_cache': {
        // Placeholder - cache is in Python worker
        return { content: [{ type: 'text', text: JSON.stringify({ status: 'cache_cleared' }) }] };
      }
      
      case 'restore_memory': {
        const filename = args?.filename as string;
        const type = (args?.type as 'short_term' | 'long_term') || 'short_term';
        await client.restoreMemory(filename, type);
        return { content: [{ type: 'text', text: JSON.stringify({ status: 'restored', filename, type }) }] };
      }
      
      case 'consolidate': {
        const dryRun = args?.dry_run !== false;
        const result = await client.consolidate(dryRun);
        return { content: [{ type: 'text', text: JSON.stringify(result) }] };
      }

      case 'get_context': {
        // Smart context generation with tier-based loading
        const tier = args?.tier as number || 1;
        const role = args?.role as string;
        const context = await client.getContext(tier, role);
        return { content: [{ type: 'text', text: JSON.stringify(context) }] };
      }
      
      default:
        throw new Error(`Unknown tool: ${name}`);
        inputSchema: {
          type: 'object',
          properties: {
            queries: {
              type: 'array',
              items: { type: 'string' },
              description: 'List of search queries',
              minItems: 1,
            },
