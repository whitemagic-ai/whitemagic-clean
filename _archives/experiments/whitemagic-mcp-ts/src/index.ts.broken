    },
    {
      uri: 'memory://tags',
      name: 'Memory Tags',
      description: 'All available tags for categorization',
      mimeType: 'application/json',
    },
    
    // Sangha Resources (Phase C)
    {
      uri: 'sangha://workspace',
      name: 'Sangha Workspace Info',
      description: 'Current workspace configuration and storage locations',
      mimeType: 'application/json',
    },
    {
      uri: 'sangha://chat/general',
      name: 'Sangha General Chat',
      description: 'Messages from the general channel',
