load("//bazel:api.bzl", "modular_py_library")

# gazelle:default_visibility //visibility:public

package(default_visibility = ["//visibility:public"])

modular_py_library(
    name = "mojo",
    srcs = glob(["**/*.py"]),
    data = [
        "@mojo//:std",
    ],
    ignore_unresolved_imports = [
        # Optional dependency for notebook support
        "IPython",
    ],
    imports = [".."],
)
