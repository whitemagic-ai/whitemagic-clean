# Faster hashing for remote builds
startup --digest_function=blake3

# https://github.com/aspect-build/rules_js/issues/1408
startup --host_jvm_args=-DBAZEL_TRACK_SOURCE_DIRECTORIES=1

# Enable --config=(macos|windows|linux) based on the host OS
# TODO: This should be 'common', currently blocked on buildbuddy cli changes
# TODO: '=true' is required because of a buildbuddy cli bug
build --enable_platform_specific_config=true

# Show more output files when you build multiple targets
common --show_result=10

# Only env vars passed with --repo_env are propagated to repository rules
common --experimental_strict_repo_env

# More resilient to network issues with the BCR URL
common --module_mirrors=https://bcr.cloudflaremirrors.com

# https://github.com/bazelbuild/bazel/pull/27030
common --experimental_objc_fastbuild_options=

# Don't inherit magic copts for objc_library rules
common --incompatible_avoid_hardcoded_objc_compilation_flags

common --experimental_collect_system_network_usage=false

# https://github.com/aspect-build/tools_telemetry
common --repo_env=ASPECT_TOOLS_TELEMETRY=-all

# Prevent .pyc files from being generated for repository_rules, nice when debugging hermiticity
common --repo_env=PYTHONDONTWRITEBYTECODE=true

# Retry dependency download flakes
common --experimental_repository_downloader_retries=5

# Make globs that don't match anything fail
common --incompatible_disallow_empty_glob

common --platforms=@mojo_host_platform
common --host_platform=@mojo_host_platform

# TODO: remove when https://github.com/bazelbuild/bazel/issues/25145 is fixed
info --platforms=@platforms//host

# Improve sandboxed build performance by reusing symlink trees
common --reuse_sandbox_directories

# Disable networking for sandboxed tests
common --sandbox_default_allow_network=false

# Pass tags to underlying actions in rules
common --incompatible_allow_tags_propagation

# Disable legacy __init__.py creation behavior
common --incompatible_default_to_explicit_init_py

# Reduce disk usage if using multiple clones
common --experimental_repository_cache_hardlinks

# Increase max test log size
common --experimental_ui_max_stdouterr_bytes=4000000

# TODO: Break lit tests finding FileCheck
# Disable legacy duplicate runfiles creation
common --legacy_external_runfiles=false
common --build_runfile_links=false

# Generate a smaller manifest which is nicer for remote exec
common --incompatible_compact_repo_mapping_manifest

# Make sure test outputs exist without having to unarchive
common --zip_undeclared_test_outputs=false

# https://github.com/bazelbuild/rules_python/issues/2445
common --@rules_python//python/config_settings:exec_tools_toolchain=disabled

# Make flag easier to write on the command line
build --flag_alias=mojocopt=@rules_mojo//:mojo_copt
build --flag_alias=mojopackagecopt=@rules_mojo//:mojo_package_copt

# Disable cc_library's underlying shared library because of circular dependency linking issues
build --dynamic_mode=off
build --features=-supports_dynamic_linker

# Make sure user installed python modules don't make it in to the build
common --repo_env=PYTHONNOUSERSITE=affirmative

# Make sure repository rules don't use host tools
common --repo_env=CC=false
common --repo_env=CXX=false

# Force hermetic toolchain, make sure we don't accidentally used the default one
common --repo_env=BAZEL_DO_NOT_DETECT_CPP_TOOLCHAIN=1
common --repo_env=BAZEL_NO_APPLE_CPP_TOOLCHAIN=1

# Make sure we use llvm-ar on macOS for exec config too
common --experimental_propagate_custom_flag=@rules_cc//cc/toolchains/args/archiver_flags:use_libtool_on_macos
# Always use llvm-ar which works fine for macOS
common --@rules_cc//cc/toolchains/args/archiver_flags:use_libtool_on_macos=false

# Enable parse_headers when the feature is added (only applies to first party code)
common --process_headers_in_dependencies

build --remote_retries=2
build --remote_timeout=10m
# Buildbuddy cache optimization recommendations
build --experimental_profile_include_primary_output
build --experimental_profile_include_target_label
build --remote_cache_async
build --experimental_remote_cache_ttl=14d
build --remote_cache_compression
build --experimental_remote_cache_compression_threshold=100
build --legacy_important_outputs=false
build --slim_profile=false

# Include full test log in failed tests
build --test_output=errors
build --test_summary=terse

# Disable crash reporting for all tests and runs, test rules can override this
build --action_env=MODULAR_CRASH_REPORTING_ENABLED=false --host_action_env=MODULAR_CRASH_REPORTING_ENABLED=false
build --test_env=MODULAR_CRASH_REPORTING_ENABLED=false
run --run_env=MODULAR_CRASH_REPORTING_ENABLED=false

# Disable telemetry for all tests and runs, test rules can override this
build --action_env=MODULAR_TELEMETRY_ENABLED=false --host_action_env=MODULAR_TELEMETRY_ENABLED=false
build --test_env=MODULAR_TELEMETRY_ENABLED=false
run --run_env=MODULAR_TELEMETRY_ENABLED=false

# Fix parallel tests competing for a single CPU on graviton
build --test_env=KMP_AFFINITY=none

# Differentiate between accidental 'bazel run' vs 'bazel test'
test --test_env=MODULAR_RUNNING_TESTS=true

# Default GPU memory restrictions to 0, all tests must override this
build --test_env=MODULAR_DEVICE_CONTEXT_MEMORY_MANAGER_ONLY=true
build --test_env=MODULAR_DEVICE_CONTEXT_MEMORY_MANAGER_SIZE=0
build --test_env=MODULAR_DEVICE_CONTEXT_MEMORY_MANAGER_CHUNK_PERCENT=100

# Allow --modify_execution_info to be passed any number of times
common --incompatible_modify_execution_info_additive

# Reduce the impact of transitions on rebuilding C++ files
build --modify_execution_info=CppArchive=+supports-path-mapping
build --modify_execution_info=CcLtoBackendCompile=+supports-path-mapping
# TODO: This isn't supported by bazel yet
# build --modify_execution_info=CppLTOIndexing=+supports-path-mapping
build --modify_execution_info=CppCompile=+supports-path-mapping
build --modify_execution_info=CppModuleMap=+supports-path-mapping
build --modify_execution_info=Objc.*=+supports-path-mapping
build --experimental_output_paths=strip

# These are required to avoid issues caused by dynamic linking on OS X, which
# is documented in detail here: https://github.com/sorbet/sorbet/issues/1281
# Set base macOS deployment target otherwise the target depends on the host OS
build --macos_minimum_os=11.0 --host_macos_minimum_os=11.0

build --@llvm-project//third-party:llvm_enable_zstd=false
build --experimental_propagate_custom_flag=@llvm-project//third-party:llvm_enable_zstd
build --@llvm-project//lldb:enable_libedit=true
build --experimental_propagate_custom_flag=@llvm-project//lldb:enable_libedit
build --@llvm-project//lldb:enable_curses=true
build --experimental_propagate_custom_flag=@llvm-project//lldb:enable_curses
build --@llvm-project//llvm:pfm=disable
build --experimental_propagate_custom_flag=@llvm-project//llvm:pfm
build --@llvm-project//mlir:enable_cuda=true
build --experimental_propagate_custom_flag=@llvm-project//mlir:enable_cuda

# Enable mypy running on python builds
build --aspects=//bazel/pip:mypy.bzl%mypy_aspect
build --output_groups=+mypy

build:disable-mypy --output_groups=-mypy

build:disable-lint --config=disable-mypy

build --remote_download_outputs=toplevel
build --remote_download_regex='.*\.(inc|h)$'
# Required for debug info references from binaries
build:macos --remote_download_regex='.*\.(a|lo|o|dylib)$'
build --experimental_remote_cache_eviction_retries=3
build --grpc_keepalive_time=30s
build --remote_upload_local_results
build --remote_exec_header=x-buildbuddy-platform.default-timeout=15m
# Set local builds to higher than CI priority
build --remote_execution_priority=-1

build:cache --bes_backend=grpcs://modular.buildbuddy.io
build:cache --bes_results_url=https://modular.buildbuddy.io/invocation/
build:cache --experimental_remote_downloader=grpcs://modular.buildbuddy.io
build:cache --experimental_remote_downloader_local_fallback
build:cache --remote_cache=grpcs://modular.aws-us-west-2.buildbuddy.io

build:remote --config=cache
build:remote --remote_executor=grpcs://modular.buildbuddy.io
build:remote --local_test_jobs=HOST_CPUS
build:remote --jobs=1000
build:remote --repo_env=MODULAR_REMOTE_EXEC=1

# Enable dynamic execution
build --internal_spawn_scheduler
# Enable dynamic execution for exec config, helpful if remote exec is queueing
build --experimental_dynamic_exclude_tools=false
build:linux --spawn_strategy=dynamic,remote,worker,sandboxed,standalone
build:macos --spawn_strategy=remote,worker,sandboxed,standalone
build:macos --strategy=CppCompile=dynamic,remote,worker,sandboxed,standalone
build:macos --strategy=CppLink=dynamic,remote,worker,sandboxed,standalone

# https://github.com/bazelbuild/bazel/issues/25221
build --strategy=TestRunner=remote,worker,sandboxed,standalone

build:linux --build_metadata=TAG_HOST_OS=linux
build:linux --build_metadata=TAG_TARGET_OS=linux
build:macos --build_metadata=TAG_HOST_OS=macos
build:macos --build_metadata=TAG_TARGET_OS=macos

# Separate CI config that doesn't affect build output for verifying we share caches
build:ci-no-config --curses=no
build:ci-no-config --build_metadata=ROLE=CI
build:ci-no-config --config=cache
build:ci-no-config --disk_cache=
build:ci-no-config --ui_event_filters=+WARNING
build:ci-no-config --verbose_failures
# Disable dynamic execution for remote exec
build:ci-no-config --spawn_strategy=remote,worker,sandboxed,standalone
build:ci-no-config --strategy=CppCompile=remote,worker,sandboxed,standalone
build:ci-no-config --strategy=CppLink=remote,worker,sandboxed,standalone

build:ci --config=ci-no-config
# Set CI builds to lower priority than local builds, some CI builds override this
build:ci --remote_execution_priority=20
test:ci --remote_download_outputs=minimal

build:ci-gpu-common --config=ci
build:ci-gpu-common --test_tag_filters=gpu,-lint-test

build:remote-h100 --config=remote
build:remote-h100 --repo_env=MODULAR_SKIP_AUTO_PLATFORMS=1
build:remote-h100 --platforms=//:h100-platform
build:remote-h100 --extra_execution_platforms=//:m7i-platform,//:h100-platform,@mojo_host_platform
build:remote-h100 --spawn_strategy=remote,worker,sandboxed,standalone
build:remote-h100 --repo_env=MODULAR_TARGET=linux:x86_64
build:remote-h100 --build_metadata=TAG_GPU=h100
build:remote-h100 --build_metadata=TAG_TARGET_OS=linux

build:ci-remote-h100 --config=ci-gpu-common
build:ci-remote-h100 --config=remote-h100
build:ci-remote-h100 --test_keep_going=false

build:remote-b200 --config=remote
build:remote-b200 --repo_env=MODULAR_SKIP_AUTO_PLATFORMS=1
build:remote-b200 --platforms=//:b200-platform
build:remote-b200 --extra_execution_platforms=//:m7i-platform,//:b200-platform,@mojo_host_platform
build:remote-b200 --spawn_strategy=remote,worker,sandboxed,standalone
build:remote-b200 --repo_env=MODULAR_TARGET=linux:x86_64
build:remote-b200 --build_metadata=TAG_GPU=b200
build:remote-b200 --build_metadata=TAG_TARGET_OS=linux

build:ci-remote-b200 --config=ci-gpu-common
build:ci-remote-b200 --config=remote-b200
build:ci-remote-b200 --test_keep_going=false

build:remote-mi355 --config=remote
build:remote-mi355 --repo_env=MODULAR_SKIP_AUTO_PLATFORMS=1
build:remote-mi355 --platforms=//:mi355-platform
build:remote-mi355 --extra_execution_platforms=//:m7i-platform,//:mi355-platform,@mojo_host_platform
build:remote-mi355 --spawn_strategy=remote,worker,sandboxed,standalone
build:remote-mi355 --repo_env=MODULAR_TARGET=linux:x86_64
build:remote-mi355 --build_metadata=TAG_GPU=mi355
build:remote-mi355 --build_metadata=TAG_TARGET_OS=linux

build:ci-remote-mi355 --config=ci-gpu-common
build:ci-remote-mi355 --config=remote-mi355
# TODO: Enable once tests are fixed
# build:ci-remote-mi355 --test_keep_going=false

# TODO: Remove once transitives are fixed
common --incompatible_autoload_externally=@rules_shell,@com_google_protobuf,java_binary,+JavaInfo,+@rules_cc
