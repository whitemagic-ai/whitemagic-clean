load("//bazel:api.bzl", "mojo_filecheck_test", "mojo_test")

package(default_visibility = ["//max:consumers"])

_EXTRA_COPTS = {
    "test_layout_tensor_copy.mojo": [
        "--debug-level",
        "full",
    ],
    "test_layout_tensor_copy_amd.mojo": [
        "--debug-level",
        "full",
    ],
    "test_layout_tensor_copy_nvidia.mojo": [
        "--debug-level",
        "full",
    ],
}

_H100_TESTS = [
    "test_stmatrix.mojo",
    "test_tensor_core_sm90.mojo",
    "test_tensormap_replace_insts.mojo",
    "test_tma_3d_async_copy.mojo",
    "test_tma_4d_async_copy.mojo",
    "test_tma_5d_async_copy.mojo",
    "test_tma_async.mojo",
    "test_tma_async_mc.mojo",
    "test_tma_mc_swizzle.mojo",
    "test_tma_swizzle.mojo",
    "test_wgmma.mojo",
    "test_wgmma_e4m3_e5m2_layouts_f16.mojo",
    "test_wgmma_e4m3_e5m2_layouts_f32.mojo",
    "test_wgmma_int8_uint8_layouts.mojo",
    "test_wgmma_layouts.mojo",
    "test_wgmma_with_static_tuple_output_bf16.mojo",
    "test_wgmma_with_static_tuple_output_fp8.mojo",
]

_APPLE_GPU_INCOMPATIBLE = select({
    "//:apple_gpu": ["@platforms//:incompatible"],
    "//conditions:default": [],
})

_EXTRA_CONSTRAINTS = {
    src: ["//:h100_gpu"]
    for src in _H100_TESTS
} | {
    # TMA tensormap update test - uses NVIDIA-specific mbarrier and TMA
    # Works on any NVIDIA GPU (H100+), incompatible with AMD
    "test_grouped_tensormap_update.mojo": ["//:nvidia_gpu"],
} | {
    "test_layout_tensor_copy_amd.mojo": ["//:amd_gpu"],
    "test_layout_tensor_copy_nvidia.mojo": ["//:nvidia_gpu"],
    # compile_info emits PTX assembly, which is NVIDIA-specific
    "test_layout_tensor_indexlist_codegen.mojo": ["//:nvidia_gpu"],
    "test_ldmatrix.mojo": ["//:nvidia_gpu"],  # FIXME: KERN-1377
    "test_tensor_core_amd.mojo": ["//:amd_gpu"],
    "test_tensor_core_mi300x.mojo": ["//:mi300x_gpu"],
    "test_tensor_core_mi355x.mojo": ["//:mi355_gpu"],
    "test_tensor_core_amd2.mojo": ["//:amd_gpu"],
    "test_tensor_core_nvidia.mojo": ["//:nvidia_gpu"],
    "test_tiled_matmul_gpu.mojo": ["//:nvidia_gpu"],  # FIXME: KERN-1377
    "test_vendor_blas_matmul.mojo": select({
        "//:h100_gpu": [],
        "//:mi300x_gpu": [],
        "//conditions:default": ["@platforms//:incompatible"],
    }),
    "test_wgmma_e4m3_e5m2_layouts_f16.mojo": ["@platforms//:incompatible"],  # FIXME: KERN-1874
    "test_wgmma_e4m3_e5m2_layouts_f32.mojo": ["@platforms//:incompatible"],  # FIXME: KERN-1874
    "test_layout_mma.mojo": _APPLE_GPU_INCOMPATIBLE,  # FIXME: PRDT-506
    "test_layout_tensor_copy.mojo": _APPLE_GPU_INCOMPATIBLE,  # FIXME: PRDT-506
    "test_tensor_gpu.mojo": _APPLE_GPU_INCOMPATIBLE,  # FIXME: PRDT-506
    "test_matmul.mojo": _APPLE_GPU_INCOMPATIBLE,  # FIXME: MOCO-2415
}

_FILECHECK_TESTS = [
    "test_codegen_to_llvm.mojo",
    "test_layout_tensor_copy.mojo",
    "test_layout_tensor_copy_amd.mojo",
    "test_layout_tensor_copy_nvidia.mojo",
    "test_tensor_core_amd.mojo",
    "test_tensor_core_mi300x.mojo",
    "test_tensor_core_mi355x.mojo",
    "test_tensor_core_amd2.mojo",
    "test_tensor_core_nvidia.mojo",
    "test_tensor_core_sm90.mojo",
    "test_tiled_matmul_gpu.mojo",
    "test_wgmma_e4m3_e5m2_layouts_f16.mojo",
    "test_wgmma_e4m3_e5m2_layouts_f32.mojo",
    "test_wgmma_int8_uint8_layouts.mojo",
    "test_wgmma_layouts.mojo",
]

[
    mojo_test(
        name = src + ".test",
        size = "large",
        srcs = [
            src,
            "matmul_kernels.mojo",
        ],
        exec_properties = {
            "test.resources:gpu-memory": "1.5",
        },
        main = src,
        tags = ["gpu"],
        target_compatible_with = ["//:has_gpu"] + _EXTRA_CONSTRAINTS.get(src, []),
        deps = [
            "//max:internal_utils",
            "//max:kv_cache",
            "//max:layout",
            "//max:linalg",
            "//max:nn",
            "//max:quantization",
            "@mojo//:std",
        ],
    )
    for src in glob(
        ["**/*.mojo"],
        exclude = _FILECHECK_TESTS + [
            "test_tensor_core_amd_utils.mojo",  # Imported source, not a test
            "matmul_kernels.mojo",  # Imported source, not a test
            "tensor_core_kernels.mojo",  # Imported source, not a test
        ],
    )
]

[
    mojo_filecheck_test(
        name = src + ".test",
        size = "large",
        srcs = [
            src,
            "tensor_core_kernels.mojo",
            "test_tensor_core_amd_utils.mojo",
        ],
        copts = _EXTRA_COPTS.get(src, []),
        # KERN-2339: naive_matmul kernel has out-of-bounds indexing bugs that need proper fixing
        enable_assertions = src not in ["test_tiled_matmul_gpu.mojo"],
        main = src,
        tags = ["gpu"],
        target_compatible_with = ["//:has_gpu"] + _EXTRA_CONSTRAINTS.get(src, []),
        deps = [
            "//max:internal_utils",
            "//max:kv_cache",
            "//max:linalg",
            "//max:nn",
            "//max:quantization",
            "@mojo//:std",
        ],
    )
    for src in _FILECHECK_TESTS
]
