infixr 80 (^);
infixl 70 (*);
infixl 70 (%);
infixl 70 (/);
infixl 70 cdiv;
infixl 70 cmod;
infixr 60 (++);
infixl 60 (+);
infixl 60 (-);
infixr 55 (++.);
