// See `module std/core/vector` for vector operations.
pub type vector[102,1,102,18] <a> :: V -> V ;
// The `:void` type is empty and has no constructors.
// See also the `:unit` unit type and the `:bool` type.
pub type void[168,1,168,13] ;
 
