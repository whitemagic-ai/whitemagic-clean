/* Primitive types and functions.

   This module is implicitly imported and all functions and types
   are always available.
   These types are required to be defined for the compiler
   to work correctly (i.e. types like `:int` or `:div`)

   The _kinds_ of types are all builtin:

   * `V`   value types (i.e. the star kind)
   * `E`   effect rows (`<div,exn|e>`)
   * `X`   a single effect (`div`, `exn`, `parse`, etc.), also called atomic effect
   * `H`   heap types (always a phantom type without actual values)
   * `HX`  a short-hand for user defined effect handlers of kind `(E,V) -> V`

*/
module interface std/core/types
 
//------------------------------
//#kki: import declarations
 
 
//------------------------------
//#kki: external imports
 
extern import {
  c  {
    "header-end-include-inline"="\x0A\x0A\x0A\x0A\x0A\x0A/*---------------------------------------------------------------------------\x0A  Copyright 2020-2023, Microsoft Research, Daan Leijen.\x0A\x0A  This is free software; you can redistribute it and/or modify it under the\x0A  terms of the Apache License, Version 2.0. A copy of the License can be\x0A  found in the LICENSE file at the root of this distribution.\x0A---------------------------------------------------------------------------*/\x0Astatic inline kk_field_addr_t kk_field_addr_create(void* p, kk_context_t* ctx) {\x0A  return kk_internal_ptr_box((kk_box_t*)p, ctx);\x0A}\x0A\x0Astatic inline kk_box_t* kk_field_addr_ptr(kk_field_addr_t faddr, kk_context_t* ctx) {\x0A  return kk_internal_ptr_unbox(faddr, ctx);\x0A}\x0A\x0Astatic inline kk_decl_const kk_field_addr_t kk_field_addr_null(void) {\x0A  return kk_box_null();\x0A}\x0A\x0Astatic inline kk_decl_const kk_box_t kk_cctx_hole(void) {\x0A  return kk_box_null();  // for now, this must be a value; see `kklib/src/refcount.c:kk_cctx_copy_apply`\x0A}\x0A\x0Astatic inline kk_decl_const kk_std_core_types__cctx kk_cctx_empty(kk_context_t* ctx) {\x0A  return kk_std_core_types__new_Cctx( kk_cctx_hole(), kk_field_addr_null(), ctx);\x0A}\x0A\x0Astatic inline kk_std_core_types__cctx kk_cctx_create( kk_box_t res, kk_field_addr_t field, kk_context_t* ctx) {\x0A  return kk_std_core_types__new_Cctx( res, field, ctx);\x0A}\x0A\x0Astatic inline kk_decl_const bool kk_cctx_is_empty( kk_std_core_types__cctx cctx ) {\x0A  return kk_box_eq(cctx.holeptr,kk_field_addr_null()); // kk_box_is_value(cctx.res);\x0A}\x0A\x0Astatic inline kk_decl_const bool kk_cctx_is_valid( kk_std_core_types__cctx cctx ) {\x0A  return !kk_cctx_is_empty(cctx); // kk_box_is_ptr(cctx.res);\x0A}\x0A\x0A// apply a context\x0Astatic inline kk_box_t kk_cctx_apply( kk_std_core_types__cctx acc, kk_box_t child, kk_context_t* ctx ) {\x0A  // note: written like this for best codegen; be careful when rewriting.\x0A  if kk_unlikely(kk_cctx_is_empty(acc)) {\x0A    return child;\x0A  }\x0A  else if kk_likely(kk_block_is_unique(kk_ptr_unbox(acc.res,ctx))) {\x0A    *kk_field_addr_ptr(acc.holeptr,ctx) = child;   // in-place update the hole with the child\x0A    return acc.res;\x0A  }\x0A  #if !defined(KK_CCTX_NO_CONTEXT_PATH)\x0A  else {\x0A    kk_assert_internal(!kk_block_is_unique(kk_ptr_unbox(acc.res,ctx)));\x0A    return kk_cctx_copy_apply(acc.res,kk_field_addr_ptr(acc.holeptr,ctx),child,ctx);  // copy the context path to the hole and compose with the child\x0A  }\x0A  #endif\x0A}\x0A\x0A// apply linear, acc will be unique\x0A// calls to kk_cctx_apply_linear are generated by the compiler during TRMC in affine contexts.\x0Astatic inline kk_box_t kk_cctx_apply_linear( kk_std_core_types__cctx acc, kk_box_t child, kk_context_t* ctx ) {\x0A  #if 1\x0A  if kk_likely(!kk_cctx_is_empty(acc)) {\x0A    kk_assert_internal(kk_block_is_unique(kk_ptr_unbox(acc.res,kk_get_context())));\x0A    *kk_field_addr_ptr(acc.holeptr,ctx) = child;\x0A    return acc.res;\x0A  }\x0A  else {\x0A    return child;\x0A  }\x0A  #else\x0A  // this form entices conditional moves (but seems slower in general)\x0A  if (kk_cctx_is_valid(acc)) { *kk_field_addr_ptr(acc.holeptr,ctx) = child; }\x0A  return (kk_cctx_is_valid(acc) ? acc.res : child);\x0A  #endif\x0A}\x0A\x0A\x0A// extend a context with a guaranteed non-empty context\x0Astatic inline kk_std_core_types__cctx kk_cctx_extend( kk_std_core_types__cctx acc, kk_box_t child, kk_field_addr_t field, kk_context_t* ctx  ) {\x0A  return kk_std_core_types__new_Cctx( kk_cctx_apply(acc,child,ctx), field, ctx );\x0A}\x0A\x0A// extend a context with a guaranteed non-empty context, and where acc will be unique\x0A// calls to kk_cctx_extend_linear are generated by the compiler during TRMC in affine contexts.\x0Astatic inline kk_std_core_types__cctx kk_cctx_extend_linear( kk_std_core_types__cctx acc, kk_box_t child, kk_field_addr_t field, kk_context_t* ctx  ) {\x0A  return kk_std_core_types__new_Cctx( kk_cctx_apply_linear(acc,child,ctx), field, ctx );\x0A}\x0A\x0A// defined as non-inline for better fast-path\x0Akk_std_core_types__cctx kk_cctx_compose_shared( kk_std_core_types__cctx acc1, kk_std_core_types__cctx acc2, kk_context_t* ctx  );\x0A\x0A// compose a context\x0Astatic inline kk_std_core_types__cctx kk_cctx_compose( kk_std_core_types__cctx acc1, kk_std_core_types__cctx acc2, kk_context_t* ctx  ) {\x0A  if kk_unlikely(kk_cctx_is_empty(acc2)) {\x0A    return acc1;\x0A  }\x0A  else if kk_likely(kk_block_is_unique(kk_ptr_unbox(acc2.res,ctx))) {\x0A    return kk_cctx_extend(acc1,acc2.res,acc2.holeptr,ctx);\x0A  }\x0A  else {\x0A    return kk_cctx_compose_shared(acc1,acc2,ctx);\x0A  }\x0A}\x0A\x0A// acc1 & acc2 will be unique\x0Astatic inline kk_std_core_types__cctx kk_cctx_compose_linear( kk_std_core_types__cctx acc1, kk_std_core_types__cctx acc2, kk_context_t* ctx  ) {\x0A  if kk_unlikely(kk_cctx_is_empty(acc2)) {\x0A    return acc1;\x0A  }\x0A  kk_assert_internal(kk_block_is_unique(kk_ptr_unbox(acc2.res,ctx)));\x0A  return kk_cctx_extend_linear(acc1,acc2.res,acc2.holeptr,ctx);\x0A}\x0A";
  };
};
 
