//#kki: inline definitions
 
//.inline-section
fun prepend // inline size: 3
  = fn(exn: std/core/exn/exception, pre: std/core/types/string){
    std/core/exn/Exception((std/core/types/(++)(pre, (std/core/types/(++)(": ", (match (exn) {
            ((@skip std/core/exn/Exception((@x: std/core/types/string) : std/core/types/string, (@pat@0: std/core/exn/exception-info) : std/core/exn/exception-info) : std/core/exn/exception ) as @pat: std/core/exn/exception)
               -> @x;
          }))))), (match (exn) {
        ((@skip std/core/exn/Exception((@pat@0@0: std/core/types/string) : std/core/types/string, (@x@0: std/core/exn/exception-info) : std/core/exn/exception-info) : std/core/exn/exception ) as @pat@1: std/core/exn/exception)
           -> @x@0;
      }));
  };