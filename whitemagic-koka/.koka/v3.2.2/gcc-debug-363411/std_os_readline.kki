fun prepend[28,5,28,11] : (exn : std/core/exn/exception, pre : std/core/types/string) -> std/core/exn/exception;
fun readline-err[32,8,32,19] : () -> <(std/core/console/console :: X)> (std/core/exn/error :: V -> V)<std/core/types/string>;
// Read a line of input synchronously from stdin (using UTF8 encoding).
// Read characters until either a newline is encountered (not included in the result),
// or 1023 characters have been read.
pub fun readline[22,9,22,16] : () -> <(std/core/console/console :: X),(std/core/types/handled :: ((E, V) -> V) -> X)<(std/core/exn/exn :: (E, V) -> V)>> std/core/types/string;
 
