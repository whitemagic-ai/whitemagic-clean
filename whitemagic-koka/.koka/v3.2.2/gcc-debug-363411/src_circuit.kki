fun state-to-string // inline size: 2
  = fn(s: circuit-state){
    match (s) {
      ((src/circuit/Closed() : circuit-state ) as @pat: circuit-state)
         -> "closed";
      ((src/circuit/Open() : circuit-state ) as @pat@0: circuit-state)
         -> "open";
      ((@skip src/circuit/HalfOpen() : circuit-state ) as @pat@1: circuit-state)
         -> "half-open";
    };
  };
