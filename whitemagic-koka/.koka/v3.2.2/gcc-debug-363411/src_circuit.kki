inline borrow "^" fip fun is-closed // inline size: 1
  = fn(circuit-state: circuit-state){
    match (circuit-state) {
      ((src/circuit/Closed() : circuit-state ) as @pat: circuit-state)
         -> std/core/types/True;
      (@pat@0: circuit-state)
         -> std/core/types/False;
    };
  };
inline borrow "^" fip fun is-open // inline size: 1
  = fn(circuit-state: circuit-state){
    match (circuit-state) {
      ((src/circuit/Open() : circuit-state ) as @pat: circuit-state)
         -> std/core/types/True;
      (@pat@0: circuit-state)
         -> std/core/types/False;
    };
  };
inline borrow "^" fip fun is-halfOpen // inline size: 1
  = fn(circuit-state: circuit-state){
