fun timescale/mb-to-mjd2000[82,3,82,15] : (^ timescale : timescale) -> (std/core/types/maybe :: V -> V)<(t : std/time/timestamp/timestamp, tzdelta : std/time/timestamp/timespan) -> std/num/ddouble/ddouble>;
