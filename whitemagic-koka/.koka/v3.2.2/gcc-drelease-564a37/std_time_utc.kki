// Time spans are a time duration in some time scale represented as a `:ddouble`;
// this gives it very high precision and range to represent time very precisely.
// (see the [`instant`](std_time_instant.html) module)
local alias std/time/timestamp/timespan[25,1,25,28] = std/num/ddouble/ddouble = 1;
 
//------------------------------
//#kki: type declarations
 
// `:utc-timestamp` is UTC time since 2000-01-01
pub alias utc-timestamp[308,1,308,35] = std/time/timestamp/timestamp = 1;
// Leap second adjustments. For an instant `i` after `start`:\
// ``TAI-offset = offset + (drift * days(i - drift-start))``
pub type leap-adjust[320,1,325,1] {
  // Leap second adjustments. For an instant `i` after `start`:\
// ``TAI-offset = offset + (drift * days(i - drift-start))``
  con Leap-adjust[320,17,320,27](utc-start: (utc-timestamp == 1 std/time/timestamp/timestamp), offset: (std/time/timestamp/timespan == 1 std/num/ddouble/ddouble), drift-start: (utc-timestamp == 1 std/time/timestamp/timestamp), drift: std/num/ddouble/ddouble){40,2,8} : (utc-start : (utc-timestamp == 1 std/time/timestamp/timestamp), offset : (std/time/timestamp/timespan == 1 std/num/ddouble/ddouble), drift-start : (utc-timestamp == 1 std/time/timestamp/timestamp), drift : std/num/ddouble/ddouble) -> leap-adjust = 1;
};
// A leap second table describes when UTC leap seconds occur.
pub type leaps-table[311,1,316,1] {
  // A leap second table describes when UTC leap seconds occur.
  con Leaps-table[311,17,311,27](expire: std/time/instant/instant, adjusts: (std/core/types/list :: V -> V)<leap-adjust>){0,3,8} : (expire : std/time/instant/instant, adjusts : (std/core/types/list :: V -> V)<leap-adjust>) -> leaps-table = 1;
};
// Return the UTC timescale with the latest leap second information.
pub recursive effect type utc[296,1,296,32] <(e :: E),a> :: (E, V) -> V {
  pub con @Hnd-utc[296,1,296,17](@cfc: std/core/types/int, @fun-utc: (std/core/hnd/clause0 :: (V, (E, V) -> V, E, V) -> V)<std/time/instant/timescale,(utc :: (E, V) -> V),(e :: E),a>){0,2,8} : forall<(e :: E),a> (std/core/types/int, (std/core/hnd/clause0 :: (V, (E, V) -> V, E, V) -> V)<std/time/instant/timescale,(utc :: (E, V) -> V),(e :: E),a>) -> (utc :: (E, V) -> V)<(e :: E),a> = 1;
};
 
