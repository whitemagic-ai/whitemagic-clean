fun coptic-days-before-month // inline size: 2
  = fn(year: std/core/types/int, month: std/core/types/int){
    std/core/int/(*)(30, (std/core/int/int-sub(month, 1)));
  };
fun coptic-doy-to-month // inline size: 2
  = fn(year: std/core/types/int, doy: std/core/types/int){
    val x@10002[1,0,1,0] : std/core/types/int
          = std/core/int/(/)(doy, 30);
    std/core/int/int-add(x@10002, 1);
  };
fun coptic-days-before-year // inline size: 4
  = fn(year: std/core/types/int){
    val x@10004[1,0,1,0] : std/core/types/int
      = std/core/int/(*)(365, (std/core/int/int-sub(year, 1)));
    val y@10005[1,0,1,0] : std/core/types/int
      = std/core/int/(/)(year, 4);
    std/core/int/int-add(x@10004, y@10005);
  };
fun coptic-estimate-year // inline size: 7
  = fn(days: std/core/types/int){
    match ((std/core/int/divmod((std/core/int/int-add(days, 365)), 1461))) {
      ((@skip std/core/types/Tuple2((era: std/core/types/int) : std/core/types/int, (doe: std/core/types/int) : std/core/types/int) : (std/core/types/int, std/core/types/int) ) as @pat: (std/core/types/int, std/core/types/int))
         -> val x@0@10009[1,0,1,0] : std/core/types/int
              = std/core/int/(*)(4, era);
            val y@0@10010[1,0,1,0] : std/core/types/int
              = std/core/int/(/)(doe, 366);
        std/core/types/Tuple2<std/core/types/int,(std/core/types/maybe :: V -> V)<std/core/types/int>>((std/core/int/int-add(x@0@10009, y@0@10010)), (std/core/types/Just<std/core/types/int>(364)));
    };
  };
fun coptic-days-to-yeardoy // inline size: 10
  = fn(days: std/core/types/int){
