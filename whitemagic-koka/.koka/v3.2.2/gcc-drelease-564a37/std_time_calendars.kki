  = fn(year: std/core/types/int){
    val gdays[111,7,111,11] : std/core/types/int
      = std/time/calendars/iso-days-before-year(year);
    val weekday[112,7,112,13] : std/core/types/int
      = std/core/int/(%)(gdays, 7);
    val adjust[113,7,113,12] : std/core/types/int
      = match ((std/core/int/(<=)(weekday, 3))) {
        ((std/core/types/True() : std/core/types/bool ) as @pat: std/core/types/bool)
           -> std/core/int/int-sub(0, weekday);
        ((@skip std/core/types/False() : std/core/types/bool ) as @pat@0: std/core/types/bool)
           -> std/core/int/int-sub(7, weekday);
      };
    std/core/int/int-add(gdays, adjust);
  };
