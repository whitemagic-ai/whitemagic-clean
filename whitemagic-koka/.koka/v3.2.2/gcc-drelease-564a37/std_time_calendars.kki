fun julian-adjust // inline size: 4
  = fn(is-before-march: std/core/types/bool, year: std/core/types/int){
    match (is-before-march) {
      ((std/core/types/True() : std/core/types/bool ) as @pat: std/core/types/bool)
         -> 0;
