fun xticks[34,8,34,13] : () -> <(std/core/types/ndet :: X)> (std/core/types/float64, std/core/types/float64);
// Return a high-resolution time stamp in fractional SI seconds.
// The duration is guaranteed to be monotonically increasing
// and have at least millisecond resolution.
pub fun ticks[30,9,30,13] : () -> <(std/core/types/ndet :: X)> std/time/duration/duration;
// Return the smallest time difference in seconds that `ticks` can measure.
fun xticks-resolution[44,8,44,24] : () -> <(std/core/types/ndet :: X)> std/core/types/float64;
// Return the smallest time difference in seconds that `ticks` can measure.
pub fun ticks-resolution[40,9,40,24] : () -> <(std/core/types/ndet :: X)> std/time/duration/duration;
